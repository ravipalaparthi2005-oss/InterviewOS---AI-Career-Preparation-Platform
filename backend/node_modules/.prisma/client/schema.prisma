datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String           @id @default(uuid())
  email       String           @unique
  password    String
  name        String
  role        String // "STUDENT", "RECRUITER", "ADMIN"
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resumes     Resume[]
  interviews  MockInterview[]
  roadmaps    Roadmap[]
  portfolios  Portfolio[]
  submissions CodeSubmission[]
}

model Resume {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename        String
  atsScore        Int
  feedback        String // JSON string containing detailed review
  skills          String // Comma-separated or JSON list of detected skills
  missingKeywords String // Comma-separated or JSON list of missing keywords
  createdAt       DateTime   @default(now())
  jobMatches      JobMatch[]
}

model JobMatch {
  id             String   @id @default(uuid())
  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobTitle       String
  jobDescription String
  matchScore     Int
  feedback       String // JSON string containing detailed feedback & skill gap analysis
  readinessScore Int // Hiring readiness score
  createdAt      DateTime @default(now())
}

model MockInterview {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String // "TECHNICAL", "BEHAVIORAL", "HR", "SYSTEM_DESIGN"
  status          String // "PENDING", "COMPLETED"
  score           Int
  duration        Int // In seconds
  transcript      String // JSON string of conversation [ { role: "interviewer" | "user", text: "..." } ]
  feedback        String // JSON string with detailed feedback, ratings, eye contact score, filler words
  companySpecific String? // e.g., "Google", "Stripe"
  createdAt       DateTime @default(now())
}

model Roadmap {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  targetJob   String
  steps       String // JSON string with list of steps, milestones, and links
  currentStep Int      @default(0)
  createdAt   DateTime @default(now())
}

model Portfolio {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme      String // "dark", "light", "glassmorphism"
  skills     String // JSON string of skills
  projects   String // JSON string of projects
  experience String // JSON string of experiences
  aboutMe    String
  slug       String   @unique
  createdAt  DateTime @default(now())
}

model CodingProblem {
  id              String           @id @default(uuid())
  title           String
  description     String // Problem statement
  difficulty      String // "EASY", "MEDIUM", "HARD"
  category        String // "Arrays", "Trees", "Graphs", etc.
  constraints     String // JSON string of constraints
  examples        String // JSON string of examples
  testCases       String // JSON string of test cases
  sampleSolution  String // Sample solution code
  timeComplexity  String // e.g., "O(n log n)"
  spaceComplexity String // e.g., "O(n)"
  tags            String // Comma-separated tags
  createdAt       DateTime         @default(now())
  submissions     CodeSubmission[]
}

model CodeSubmission {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language      String // "javascript", "python", "cpp", "java"
  code          String // User's submitted code
  passed        Int // Number of test cases passed
  total         Int // Total test cases
  executionTime Int // In milliseconds
  memoryUsed    Int? // In MB (if available)
  status        String // "SUBMITTED", "PASSED", "FAILED"
  feedback      String? // JSON string of test results and feedback
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SystemAnalytics {
  id        String   @id @default(uuid())
  metric    String // "AI_TOKEN_USAGE", "ACTIVE_USERS", "API_LATENCY", "PLATFORM_COST"
  value     Float
  timestamp DateTime @default(now())
}
